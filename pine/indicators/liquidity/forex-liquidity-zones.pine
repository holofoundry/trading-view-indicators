//@version=6
indicator("Forex Liquidity Zones", overlay=true, max_boxes_count=500, max_labels_count=500)

displayGroup = "Display"
timeframeGroup = "Liquidity Timeframe"
styleGroup = "Style"
colorGroup = "Colors"

liquidityTimeframe = input.timeframe("60", "Liquidity timeframe", group=timeframeGroup)
pivotLength = input.int(3, "Swing length", minval=1, maxval=20, group=timeframeGroup)
maxZones = input.int(20, "Maximum zones", minval=1, maxval=100, group=displayGroup)
showBuySideZones = input.bool(true, "Show buy-side liquidity", group=displayGroup)
showSellSideZones = input.bool(true, "Show sell-side liquidity", group=displayGroup)
showLabels = input.bool(true, "Show zone labels", group=styleGroup)
zoneBufferMode = input.string("ATR", "Zone buffer mode", options=["ATR", "Percent"], group=styleGroup)
atrLength = input.int(14, "ATR length", minval=1, group=styleGroup)
atrMultiplier = input.float(0.25, "ATR buffer", minval=0.01, step=0.01, group=styleGroup)
percentBuffer = input.float(0.10, "Percent buffer", minval=0.01, step=0.01, group=styleGroup)
zoneTransparency = input.int(82, "Zone transparency", minval=0, maxval=100, group=styleGroup)
labelSizeChoice = input.string("Small", "Label size", options=["Small", "Normal", "Large"], group=styleGroup)
extendActiveZones = input.bool(true, "Extend active zones to the right", group=styleGroup)

buySideColor = input.color(color.rgb(215, 77, 77), "Buy-side liquidity color", group=colorGroup)
sellSideColor = input.color(color.rgb(72, 180, 120), "Sell-side liquidity color", group=colorGroup)
sweptColor = input.color(color.rgb(110, 110, 110), "Swept zone color", group=colorGroup)

var box[] buyBoxes = array.new_box()
var label[] buyLabels = array.new_label()
var float[] buyBottoms = array.new_float()
var bool[] buyActive = array.new_bool()

var box[] sellBoxes = array.new_box()
var label[] sellLabels = array.new_label()
var float[] sellTops = array.new_float()
var bool[] sellActive = array.new_bool()

f_label_size(choice) =>
    switch choice
        "Normal" => size.normal
        "Large" => size.large
        => size.small

zoneLabelSize = f_label_size(labelSizeChoice)

f_zone_buffer(level, atrValue) =>
    switch zoneBufferMode
        "Percent" => level * percentBuffer / 100.0
        => atrValue * atrMultiplier

f_trim_buy_zones() =>
    while array.size(buyBoxes) > maxZones
        oldBox = array.shift(buyBoxes)
        box.delete(oldBox)
        oldLabel = array.shift(buyLabels)
        if not na(oldLabel)
            label.delete(oldLabel)
        array.shift(buyBottoms)
        array.shift(buyActive)

f_trim_sell_zones() =>
    while array.size(sellBoxes) > maxZones
        oldBox = array.shift(sellBoxes)
        box.delete(oldBox)
        oldLabel = array.shift(sellLabels)
        if not na(oldLabel)
            label.delete(oldLabel)
        array.shift(sellTops)
        array.shift(sellActive)

htfPivotHigh = request.security(syminfo.tickerid, liquidityTimeframe, ta.pivothigh(high, pivotLength, pivotLength))
htfPivotHighTime = request.security(syminfo.tickerid, liquidityTimeframe, not na(ta.pivothigh(high, pivotLength, pivotLength)) ? time[pivotLength] : na)
htfPivotLow = request.security(syminfo.tickerid, liquidityTimeframe, ta.pivotlow(low, pivotLength, pivotLength))
htfPivotLowTime = request.security(syminfo.tickerid, liquidityTimeframe, not na(ta.pivotlow(low, pivotLength, pivotLength)) ? time[pivotLength] : na)
htfAtr = request.security(syminfo.tickerid, liquidityTimeframe, ta.atr(atrLength))

var int lastHighPivotTime = na
var int lastLowPivotTime = na

if showBuySideZones and not na(htfPivotHigh) and (na(lastHighPivotTime) or htfPivotHighTime != lastHighPivotTime)
    buyBuffer = f_zone_buffer(htfPivotHigh, htfAtr)
    buyTop = htfPivotHigh + buyBuffer
    buyBottom = htfPivotHigh
    buyBox = box.new(left=htfPivotHighTime, top=buyTop, right=time, bottom=buyBottom, xloc=xloc.bar_time, bgcolor=color.new(buySideColor, zoneTransparency), border_color=buySideColor)
    label buyLabel = na
    if showLabels
        buyLabel := label.new(htfPivotHighTime, buyTop, "Buy-side liquidity\n" + liquidityTimeframe, xloc=xloc.bar_time, style=label.style_label_down, color=buySideColor, textcolor=color.white, size=zoneLabelSize)
    array.push(buyBoxes, buyBox)
    array.push(buyLabels, buyLabel)
    array.push(buyBottoms, buyBottom)
    array.push(buyActive, true)
    f_trim_buy_zones()
    lastHighPivotTime := htfPivotHighTime

if showSellSideZones and not na(htfPivotLow) and (na(lastLowPivotTime) or htfPivotLowTime != lastLowPivotTime)
    sellBuffer = f_zone_buffer(htfPivotLow, htfAtr)
    sellTop = htfPivotLow
    sellBottom = htfPivotLow - sellBuffer
    sellBox = box.new(left=htfPivotLowTime, top=sellTop, right=time, bottom=sellBottom, xloc=xloc.bar_time, bgcolor=color.new(sellSideColor, zoneTransparency), border_color=sellSideColor)
    label sellLabel = na
    if showLabels
        sellLabel := label.new(htfPivotLowTime, sellBottom, "Sell-side liquidity\n" + liquidityTimeframe, xloc=xloc.bar_time, style=label.style_label_up, color=sellSideColor, textcolor=color.white, size=zoneLabelSize)
    array.push(sellBoxes, sellBox)
    array.push(sellLabels, sellLabel)
    array.push(sellTops, sellTop)
    array.push(sellActive, true)
    f_trim_sell_zones()
    lastLowPivotTime := htfPivotLowTime

if array.size(buyBoxes) > 0
    for i = 0 to array.size(buyBoxes) - 1
        if array.get(buyActive, i)
            zoneBox = array.get(buyBoxes, i)
            if extendActiveZones
                box.set_right(zoneBox, time)
            if high >= array.get(buyBottoms, i)
                array.set(buyActive, i, false)
                box.set_bgcolor(zoneBox, color.new(sweptColor, 88))
                box.set_border_color(zoneBox, color.new(sweptColor, 40))

if array.size(sellBoxes) > 0
    for i = 0 to array.size(sellBoxes) - 1
        if array.get(sellActive, i)
            zoneBox = array.get(sellBoxes, i)
            if extendActiveZones
                box.set_right(zoneBox, time)
            if low <= array.get(sellTops, i)
                array.set(sellActive, i, false)
                box.set_bgcolor(zoneBox, color.new(sweptColor, 88))
                box.set_border_color(zoneBox, color.new(sweptColor, 40))
