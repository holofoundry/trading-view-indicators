//@version=6
strategy(
    "London-NY 1:3 Zone Matrix [v6.4]",
    overlay = true,
    initial_capital = 10000,
    default_qty_type = strategy.percent_of_equity,
    default_qty_value = 10,
    currency = currency.USD,
    process_orders_on_close = true,
    calc_on_order_fills = true,
    pyramiding = 0
)

// =====================================================
// Inputs
// =====================================================
group_general = "General Settings"
sessionTime      = input.session("0800-2100", "Trading Session (UTC)", group = group_general)
emaLength        = input.int(200, "Trend Filter EMA", minval = 1, group = group_general)
poiLookback      = input.int(10, "POI Pivot Lookback", minval = 2, group = group_general)
maxZones         = input.int(5, "Max Historical Zones to Track", minval = 1, maxval = 10, group = group_general)
zoneMaxAgeBars   = input.int(300, "Zone Max Age (bars)", minval = 10, group = group_general)
maxZoneTouches   = input.int(3, "Max Zone Touches Before Expiry", minval = 1, maxval = 10, group = group_general)
dispAtrMult      = input.float(0.8, "Displacement ATR Multiplier", minval = 0.1, step = 0.1, group = group_general)
momentumLookback = input.int(5, "Momentum Confirmation Lookback", minval = 1, group = group_general)

group_risk = "Risk Management"
rrFinal         = input.float(3.0, "Final Risk/Reward Ratio", minval = 0.5, step = 0.1, group = group_risk)
tp1Ratio        = input.float(1.0, "Partial TP Ratio", minval = 0.5, step = 0.1, group = group_risk)
ptpPercent      = input.int(50, "Partial TP %", minval = 1, maxval = 99, group = group_risk)
weeklyLimit     = input.float(2.0, "Weekly Loss Limit %", minval = 0.1, step = 0.1, group = group_risk)
atrStopMult     = input.float(2.0, "ATR Stop Multiplier", minval = 0.1, step = 0.1, group = group_risk)
minStopPips     = input.float(8.0, "Minimum Stop Distance (pips)", minval = 0.1, step = 0.1, group = group_risk)
zoneStopBuffer  = input.float(0.15, "Zone Stop Buffer ATR Multiplier", minval = 0.0, step = 0.05, group = group_risk)

group_visuals = "Visuals"
showZones      = input.bool(true, "Show Zones", group = group_visuals)
showDashboard  = input.bool(true, "Show Dashboard", group = group_visuals)
showSessionBg  = input.bool(true, "Show Session Background", group = group_visuals)

// =====================================================
// Helpers
// =====================================================
pip = syminfo.mintick * 10.0

barTouchesRange(barLow, barHigh, zLow, zHigh) =>
    barHigh >= zLow and barLow <= zHigh

rangesOverlap(aLow, aHigh, bLow, bHigh) =>
    aHigh >= bLow and aLow <= bHigh

zoneMid(zLow, zHigh) =>
    (zLow + zHigh) / 2.0

// =====================================================
// Weekly circuit breaker
// =====================================================
var float weekStartEquity = strategy.initial_capital
var int storedWeekId = na

currentWeekId = year * 100 + weekofyear

if na(storedWeekId) or currentWeekId != storedWeekId
    storedWeekId := currentWeekId
    weekStartEquity := strategy.equity

weeklyDrawdownPercent = weekStartEquity > 0 ? ((weekStartEquity - strategy.equity) / weekStartEquity) * 100.0 : 0.0
canTradeWeekly = weeklyDrawdownPercent < weeklyLimit

// =====================================================
// Indicators
// =====================================================
ema200 = ta.ema(close, emaLength)
atr = ta.atr(14)

[macdLine, signalLine, histLine] = ta.macd(close, 12, 26, 9)
bullCrossBars = ta.barssince(ta.crossover(macdLine, signalLine))
bearCrossBars = ta.barssince(ta.crossunder(macdLine, signalLine))

bullMomentum = macdLine > signalLine and (histLine > histLine[1] or (not na(bullCrossBars) and bullCrossBars <= momentumLookback))
bearMomentum = macdLine < signalLine and (histLine < histLine[1] or (not na(bearCrossBars) and bearCrossBars <= momentumLookback))

// =====================================================
// Zone storage
// Supply zone = body-high to wick-high on pivot high candle
// Demand zone = wick-low to body-low on pivot low candle
// =====================================================
var float[] supplyTop = array.new_float()
var float[] supplyBot = array.new_float()
var int[]   supplyBorn = array.new_int()
var int[]   supplyTouches = array.new_int()
var int[]   supplyLastTouchBar = array.new_int()
var bool[]  supplyActive = array.new_bool()
var line[]  supplyTopLines = array.new_line()
var line[]  supplyBotLines = array.new_line()

var float[] demandTop = array.new_float()
var float[] demandBot = array.new_float()
var int[]   demandBorn = array.new_int()
var int[]   demandTouches = array.new_int()
var int[]   demandLastTouchBar = array.new_int()
var bool[]  demandActive = array.new_bool()
var line[]  demandTopLines = array.new_line()
var line[]  demandBotLines = array.new_line()

// =====================================================
// Zone creation logic
// =====================================================
pHigh = ta.pivothigh(high, poiLookback, poiLookback)
pLow  = ta.pivotlow(low, poiLookback, poiLookback)

if not na(pHigh)
    pivotBar = bar_index - poiLookback
    candTop = high[poiLookback]
    candBot = math.max(open[poiLookback], close[poiLookback])
    displacedAway = close <= (candBot - atr[poiLookback] * dispAtrMult)

    overlapsExisting = false
    if array.size(supplyTop) > 0
        for i = 0 to array.size(supplyTop) - 1
            if array.get(supplyActive, i)
                exTop = array.get(supplyTop, i)
                exBot = array.get(supplyBot, i)
                if rangesOverlap(candBot, candTop, exBot, exTop)
                    overlapsExisting := true

    if displacedAway and not overlapsExisting
        if array.size(supplyTop) >= maxZones
            oldTopLine = array.shift(supplyTopLines)
            oldBotLine = array.shift(supplyBotLines)
            line.delete(oldTopLine)
            line.delete(oldBotLine)
            array.shift(supplyTop)
            array.shift(supplyBot)
            array.shift(supplyBorn)
            array.shift(supplyTouches)
            array.shift(supplyLastTouchBar)
            array.shift(supplyActive)

        topLine = line.new(pivotBar, candTop, bar_index, candTop, xloc = xloc.bar_index, extend = extend.none, color = color.new(color.red, 35), width = 2, style = line.style_dashed)
        botLine = line.new(pivotBar, candBot, bar_index, candBot, xloc = xloc.bar_index, extend = extend.none, color = color.new(color.red, 65), width = 2, style = line.style_dashed)

        array.push(supplyTop, candTop)
        array.push(supplyBot, candBot)
        array.push(supplyBorn, pivotBar)
        array.push(supplyTouches, 0)
        array.push(supplyLastTouchBar, na)
        array.push(supplyActive, true)
        array.push(supplyTopLines, topLine)
        array.push(supplyBotLines, botLine)

if not na(pLow)
    pivotBar = bar_index - poiLookback
    candBot = low[poiLookback]
    candTop = math.min(open[poiLookback], close[poiLookback])
    displacedAway = close >= (candTop + atr[poiLookback] * dispAtrMult)

    overlapsExisting = false
    if array.size(demandTop) > 0
        for i = 0 to array.size(demandTop) - 1
            if array.get(demandActive, i)
                exTop = array.get(demandTop, i)
                exBot = array.get(demandBot, i)
                if rangesOverlap(candBot, candTop, exBot, exTop)
                    overlapsExisting := true

    if displacedAway and not overlapsExisting
        if array.size(demandTop) >= maxZones
            oldTopLine = array.shift(demandTopLines)
            oldBotLine = array.shift(demandBotLines)
            line.delete(oldTopLine)
            line.delete(oldBotLine)
            array.shift(demandTop)
            array.shift(demandBot)
            array.shift(demandBorn)
            array.shift(demandTouches)
            array.shift(demandLastTouchBar)
            array.shift(demandActive)

        topLine = line.new(pivotBar, candTop, bar_index, candTop, xloc = xloc.bar_index, extend = extend.none, color = color.new(color.green, 35), width = 2, style = line.style_dashed)
        botLine = line.new(pivotBar, candBot, bar_index, candBot, xloc = xloc.bar_index, extend = extend.none, color = color.new(color.green, 65), width = 2, style = line.style_dashed)

        array.push(demandTop, candTop)
        array.push(demandBot, candBot)
        array.push(demandBorn, pivotBar)
        array.push(demandTouches, 0)
        array.push(demandLastTouchBar, na)
        array.push(demandActive, true)
        array.push(demandTopLines, topLine)
        array.push(demandBotLines, botLine)

// =====================================================
// Zone maintenance and selection
// =====================================================
isAtDemand = false
isAtSupply = false

float selectedDemandTop = na
float selectedDemandBot = na
int selectedDemandBorn = na

float selectedSupplyTop = na
float selectedSupplyBot = na
int selectedSupplyBorn = na

// Update demand zones
if array.size(demandTop) > 0
    for i = 0 to array.size(demandTop) - 1
        active = array.get(demandActive, i)
        zTop = array.get(demandTop, i)
        zBot = array.get(demandBot, i)
        born = array.get(demandBorn, i)
        age = bar_index - born
        topLine = array.get(demandTopLines, i)
        botLine = array.get(demandBotLines, i)

        if showZones
            line.set_x2(topLine, bar_index)
            line.set_x2(botLine, bar_index)

        if active
            invalidated = close < zBot
            expired = age > zoneMaxAgeBars

            touchedNow = barTouchesRange(low, high, zBot, zTop) and bar_index > born
            lastTouch = array.get(demandLastTouchBar, i)
            touches = array.get(demandTouches, i)

            if touchedNow and (na(lastTouch) or bar_index - lastTouch > 1)
                touches += 1
                array.set(demandTouches, i, touches)
                array.set(demandLastTouchBar, i, bar_index)

            overTouched = array.get(demandTouches, i) > maxZoneTouches

            if invalidated or expired or overTouched
                array.set(demandActive, i, false)
                line.set_color(topLine, color.new(color.green, 90))
                line.set_color(botLine, color.new(color.green, 90))
            else
                line.set_color(topLine, color.new(color.green, 35))
                line.set_color(botLine, color.new(color.green, 65))

                if touchedNow
                    if na(selectedDemandBorn) or born > selectedDemandBorn
                        isAtDemand := true
                        selectedDemandTop := zTop
                        selectedDemandBot := zBot
                        selectedDemandBorn := born

// Update supply zones
if array.size(supplyTop) > 0
    for i = 0 to array.size(supplyTop) - 1
        active = array.get(supplyActive, i)
        zTop = array.get(supplyTop, i)
        zBot = array.get(supplyBot, i)
        born = array.get(supplyBorn, i)
        age = bar_index - born
        topLine = array.get(supplyTopLines, i)
        botLine = array.get(supplyBotLines, i)

        if showZones
            line.set_x2(topLine, bar_index)
            line.set_x2(botLine, bar_index)

        if active
            invalidated = close > zTop
            expired = age > zoneMaxAgeBars

            touchedNow = barTouchesRange(low, high, zBot, zTop) and bar_index > born
            lastTouch = array.get(supplyLastTouchBar, i)
            touches = array.get(supplyTouches, i)

            if touchedNow and (na(lastTouch) or bar_index - lastTouch > 1)
                touches += 1
                array.set(supplyTouches, i, touches)
                array.set(supplyLastTouchBar, i, bar_index)

            overTouched = array.get(supplyTouches, i) > maxZoneTouches

            if invalidated or expired or overTouched
                array.set(supplyActive, i, false)
                line.set_color(topLine, color.new(color.red, 90))
                line.set_color(botLine, color.new(color.red, 90))
            else
                line.set_color(topLine, color.new(color.red, 35))
                line.set_color(botLine, color.new(color.red, 65))

                if touchedNow
                    if na(selectedSupplyBorn) or born > selectedSupplyBorn
                        isAtSupply := true
                        selectedSupplyTop := zTop
                        selectedSupplyBot := zBot
                        selectedSupplyBorn := born

// =====================================================
// Session filter
// =====================================================
inSession = not na(time(timeframe.period, sessionTime, "UTC"))

// =====================================================
// Entry conditions
// =====================================================
bool longCondition = (
    inSession and
    canTradeWeekly and
    strategy.position_size == 0 and
    close > ema200 and
    bullMomentum and
    isAtDemand and
    not na(selectedDemandTop) and
    not na(selectedDemandBot)
)

bool shortCondition = (
    inSession and
    canTradeWeekly and
    strategy.position_size == 0 and
    close < ema200 and
    bearMomentum and
    isAtSupply and
    not na(selectedSupplyTop) and
    not na(selectedSupplyBot)
)

// =====================================================
// Trade state
// =====================================================
var float entryPrice = na
var float stopLoss = na
var float partialTP = na
var float finalTP = na
var bool isBeActive = false

if strategy.position_size == 0
    entryPrice := na
    stopLoss := na
    partialTP := na
    finalTP := na
    isBeActive := false

// =====================================================
// Execution
// =====================================================
if longCondition
    minStopDistance = minStopPips * pip
    structuralStop = selectedDemandBot - (atr * zoneStopBuffer)
    structuralRisk = close - structuralStop
    finalRisk = math.max(structuralRisk, atr * atrStopMult, minStopDistance)

    entryPrice := close
    stopLoss := close - finalRisk
    partialTP := close + (finalRisk * tp1Ratio)
    finalTP := close + (finalRisk * rrFinal)

    strategy.entry("Long", strategy.long)

if shortCondition
    minStopDistance = minStopPips * pip
    structuralStop = selectedSupplyTop + (atr * zoneStopBuffer)
    structuralRisk = structuralStop - close
    finalRisk = math.max(structuralRisk, atr * atrStopMult, minStopDistance)

    entryPrice := close
    stopLoss := close + finalRisk
    partialTP := close - (finalRisk * tp1Ratio)
    finalTP := close - (finalRisk * rrFinal)

    strategy.entry("Short", strategy.short)

// =====================================================
// Management
// Use close-through-partial for a more conservative BE trigger
// =====================================================
if strategy.position_size > 0 and not isBeActive and not na(partialTP) and close >= partialTP
    isBeActive := true

if strategy.position_size < 0 and not isBeActive and not na(partialTP) and close <= partialTP
    isBeActive := true

currentSL = isBeActive ? entryPrice : stopLoss

if strategy.position_size > 0
    strategy.exit("Long PTP", from_entry = "Long", qty_percent = ptpPercent, limit = partialTP, stop = stopLoss, comment_loss = "SL", comment_profit = "PTP Hit")
    strategy.exit("Long Final", from_entry = "Long", limit = finalTP, stop = currentSL, comment_loss = "BE/SL", comment_profit = "Target Hit")

if strategy.position_size < 0
    strategy.exit("Short PTP", from_entry = "Short", qty_percent = ptpPercent, limit = partialTP, stop = stopLoss, comment_loss = "SL", comment_profit = "PTP Hit")
    strategy.exit("Short Final", from_entry = "Short", limit = finalTP, stop = currentSL, comment_loss = "BE/SL", comment_profit = "Target Hit")

// =====================================================
// Visuals
// =====================================================
plot(ema200, "Trend Filter EMA", color = color.new(color.gray, 45), linewidth = 2)
plot(strategy.position_size != 0 ? finalTP : na, "Final TP", color = color.new(color.green, 0), style = plot.style_linebr)
plot(strategy.position_size != 0 ? currentSL : na, "Active SL", color = color.new(color.red, 0), style = plot.style_linebr)

bgcolor(showSessionBg and inSession ? color.new(color.blue, 96) : na)
bgcolor(not canTradeWeekly ? color.new(color.red, 90) : na)

// =====================================================
// Dashboard
// =====================================================
var table dash = table.new(position.top_right, 2, 5, bgcolor = color.black, border_width = 1)

activeDemandCount = 0
if array.size(demandActive) > 0
    for i = 0 to array.size(demandActive) - 1
        if array.get(demandActive, i)
            activeDemandCount += 1

activeSupplyCount = 0
if array.size(supplyActive) > 0
    for i = 0 to array.size(supplyActive) - 1
        if array.get(supplyActive, i)
            activeSupplyCount += 1

if showDashboard and barstate.islast
    table.cell(dash, 0, 0, "Weekly DD", text_color = color.white)
    table.cell(dash, 1, 0, str.tostring(weeklyDrawdownPercent, "0.00") + "%", text_color = weeklyDrawdownPercent >= weeklyLimit ? color.red : color.green)

    table.cell(dash, 0, 1, "Status", text_color = color.white)
    table.cell(dash, 1, 1, canTradeWeekly ? "ACTIVE" : "LOCKED", text_color = canTradeWeekly ? color.green : color.red)

    table.cell(dash, 0, 2, "Demand Zones", text_color = color.white)
    table.cell(dash, 1, 2, str.tostring(activeDemandCount), text_color = color.green)

    table.cell(dash, 0, 3, "Supply Zones", text_color = color.white)
    table.cell(dash, 1, 3, str.tostring(activeSupplyCount), text_color = color.red)

    table.cell(dash, 0, 4, "Momentum", text_color = color.white)
    table.cell(dash, 1, 4, bullMomentum ? "BULL" : bearMomentum ? "BEAR" : "NEUTRAL", text_color = bullMomentum ? color.green : bearMomentum ? color.red : color.silver)